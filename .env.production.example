# Copy to .env.production on the server and fill in real values.
# .env.production is gitignored -- never commit real secrets.

# Public hostname Caddy serves and requests a TLS cert for.
SITE_ADDRESS=you.duckdns.org

# Go server
APP_PORT=8080
# Pin WebSocket origin checking to your HTTPS origin (the server defaults to "*").
ALLOWED_ORIGINS=https://you.duckdns.org
TICK_RATE=20
MATCH_DURATION_MS=120000

# PostgreSQL. Generate a strong password, e.g. `openssl rand -base64 24`,
# and use the SAME value in DATABASE_URL below.
POSTGRES_USER=paintwar
POSTGRES_DB=paintwar
POSTGRES_PASSWORD=change-me-strong-random
DATABASE_URL=postgres://paintwar:change-me-strong-random@database:5432/paintwar?sslmode=disable
